# ── Ollama LLM ───────────────────────────────────────────────────────────
# Only supported LLM backend. Use a local Ollama server or your friend's
# Tailscale Ollama endpoint.
# Install: https://ollama.com
# Start server: ollama serve
# Pull model:   ollama pull llama3.1:8b
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://FRIEND_TAILSCALE_IP:11434
OLLAMA_TIMEOUT_SECONDS=20

# ── Pipeline settings ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
AUDIT_DB=./outputs/audit/runs.sqlite
