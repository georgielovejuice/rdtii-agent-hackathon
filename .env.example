# ── LLM Backend ──────────────────────────────────────────────────────────
# Options: "ollama" (default, free local) | "openai" | "anthropic"
LLM_BACKEND=ollama

# ── Ollama (default — free, runs locally, no API key needed) ─────────────
# Install: https://ollama.com
# Start server: ollama serve
# Pull model:   ollama pull qwen2.5:3b
# Model options: qwen2.5:3b | llama3.2:3b | qwen2.5:7b | mistral:7b
LLM_MODEL=qwen2.5:3b
# Ollama-specific model (overrides LLM_MODEL for Ollama backend)
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── OpenAI (alternative — requires paid API key) ──────────────────────────
# LLM_BACKEND=openai
# OPENAI_API_KEY=your_openai_key_here
# LLM_MODEL=gpt-4o

# ── Anthropic (alternative — requires paid API key) ───────────────────────
# LLM_BACKEND=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here
# LLM_MODEL=claude-sonnet-4-20250514

# ── Pipeline settings ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
AUDIT_DB=./outputs/audit/runs.sqlite
